# Copy to .env for local development
# Add all these in Railway dashboard → Variables tab

# Anthropic — console.anthropic.com (you have this from MochaBot)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Redis — auto-populated when you add Redis plugin in Railway
REDIS_URL=redis://default:password@host:port

# Resend — resend.com (free, 3000 emails/month)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=hermes@yourdomain.com

# Your email address
RECIPIENT_EMAIL=your@email.com

# Web Push — run: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_MAILTO=mailto:your@email.com

# Security — any random string
CRON_SECRET=some_random_secret_string

# Your Railway app URL (set after first deploy)
APP_URL=https://hermes-production.up.railway.app
